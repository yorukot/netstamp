{
	"name": "netstamp",
	"type": "module",
	"scripts": {
		"build:docs": "pnpm --filter @netstamp/docs build",
		"build:server": "just backend-build",
		"build:web": "pnpm --filter @netstamp/web build",
		"dev:docs": "pnpm --filter @netstamp/docs dev",
		"dev:server": "just backend-dev",
		"dev:web": "pnpm --filter @netstamp/web dev",
		"format": "prettier --write .",
		"preinstall": "npx only-allow pnpm",
		"prepare": "sh -c 'command -v git >/dev/null 2>&1 && [ -d .git ] && git config core.hooksPath .githooks || exit 0'",
		"test:server": "just backend-test"
	},
	"devDependencies": {
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.2"
	},
	"packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912",
	"engines": {
		"node": ">=22.12.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	}
}
