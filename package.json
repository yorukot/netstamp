{
	"name": "netstamp",
	"type": "module",
	"scripts": {
		"build:docs": "pnpm --filter @netstamp/docs build",
		"build:server": "just backend-build",
		"build:web": "pnpm --filter @netstamp/web build",
		"dev:docs": "pnpm --filter @netstamp/docs dev",
		"dev:server": "just backend-dev",
		"dev:web": "pnpm --filter @netstamp/web dev",
		"format": "prettier --write .",
		"preinstall": "npx only-allow pnpm",
		"prepare": "sh -c 'command -v git >/dev/null 2>&1 && [ -d .git ] && git config core.hooksPath .githooks || exit 0'",
		"test:server": "just backend-test"
	},
	"devDependencies": {
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.2"
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
	"engines": {
		"node": ">=22.12.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	}
}
