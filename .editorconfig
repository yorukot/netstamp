root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
tab_width = 2

# React, TypeScript, CSS, and Prettier-managed frontend files.
[*.{js,jsx,ts,tsx,mjs,cjs,css,scss,html,astro,json,jsonc}]
indent_style = tab
indent_size = 2
tab_width = 2

# Go files should stay compatible with gofmt.
[*.go]
indent_style = tab
indent_size = tab
tab_width = 4

[go.mod]
indent_style = tab
indent_size = tab
tab_width = 4

[Makefile]
indent_style = tab
indent_size = tab
tab_width = 4

[*.{yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
